# =============================================================================
# BACKEND — PRODUCTION ENVIRONMENT VARIABLES
# Smart Transportation Management System
# =============================================================================
# Platform: Railway
# Copy these values into your Railway service environment variables.
# Never commit a filled-in .env file to version control.
# =============================================================================

NODE_ENV=production
PORT=5002

# ── Database (Neon PostgreSQL) ───────────────────────────────
PGHOST=your_neon_host.neon.tech
PGPORT=5432
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_neon_password

# ── Redis (Upstash) ──────────────────────────────────────────
# Format: rediss://default:password@region.upstash.io:6379
REDIS_URL=rediss://default:your_upstash_password@region.upstash.io:6379

# ── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_64_char_secret
JWT_EXPIRES_IN=1h

# ── OTP & Booking ────────────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=10
BOOKING_RESERVATION_MINUTES=15

# ── Email (Brevo) ─────────────────────────────────────────────
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key

# ── Payment ──────────────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret
PAYMENT_SESSION_BASE_URL=https://your-payment-gateway.com/checkout

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
