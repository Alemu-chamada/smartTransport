# =============================================================================
# BACKEND — PRODUCTION ENVIRONMENT VARIABLES
# Transportation Management System
# =============================================================================
# Platform: Render (or Railway)
# Paste these into your hosting provider's environment variable settings.
# NEVER commit a filled-in .env to version control.
# =============================================================================

NODE_ENV=production
PORT=5002

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Prefer DATABASE_URL for simplicity; or set individual PGHOST/etc. variables.
DATABASE_URL=postgresql://neondb_owner:YOURPASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

PGHOST=ep-xxxx.region.aws.neon.tech
PGPORT=5432
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_neon_password

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# Must use rediss:// (TLS) for Upstash
REDIS_URL=rediss://default:your_upstash_password@region.upstash.io:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_64_char_secret
JWT_REFRESH_SECRET=replace_with_strong_64_char_refresh_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=replace_with_strong_random_session_secret

# ── Email OTP (Gmail App Password) ───────────────────────────────────────────
# Do NOT use your real Gmail password — generate an App Password:
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=smartTransportserv@gmail.com
EMAIL_PASS=your_16_digit_gmail_app_password

# ── OTP & Booking ────────────────────────────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=5
BOOKING_RESERVATION_MINUTES=15

# ── Payment ──────────────────────────────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=replace_with_payment_webhook_secret
PAYMENT_SESSION_BASE_URL=https://your-payment-gateway.com/checkout

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set AFTER deploying the frontend to Vercel
FRONTEND_URL=https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app
