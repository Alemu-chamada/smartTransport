# =============================================================================
# TRANSPORTATION MANAGEMENT SYSTEM — BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------
NODE_ENV=development          # development | production
PORT=5002

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# Option A — Single connection string (recommended for Neon / production)
DATABASE_URL=postgresql://neondb_owner:YOURPASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Option B — Individual parameters (local development)
PGHOST=localhost
PGPORT=5432
PGDATABASE=TMSDB
PGUSER=postgres
PGPASSWORD=your_local_postgres_password

# ---------------------------------------------------------------------------
# REDIS (Upstash for production, local for development)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Production example:
# REDIS_URL=rediss://default:YOURPASSWORD@region.upstash.io:6379

# ---------------------------------------------------------------------------
# JWT AUTHENTICATION
# ---------------------------------------------------------------------------
JWT_SECRET=replace_with_a_long_random_string_minimum_32_characters
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace_with_another_long_random_string_minimum_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# SESSION
# ---------------------------------------------------------------------------
SESSION_SECRET=replace_with_a_long_random_session_secret

# ---------------------------------------------------------------------------
# OTP CONFIGURATION
# ---------------------------------------------------------------------------
OTP_EXPIRES_IN_MINUTES=5

# ---------------------------------------------------------------------------
# BOOKING
# ---------------------------------------------------------------------------
BOOKING_RESERVATION_MINUTES=15

# ---------------------------------------------------------------------------
# PAYMENT
# ---------------------------------------------------------------------------
PAYMENT_WEBHOOK_SECRET=replace_with_payment_webhook_secret
PAYMENT_SESSION_BASE_URL=https://payments.example.test/checkout

# ---------------------------------------------------------------------------
# EMAIL (Nodemailer / Gmail App Password)
# ---------------------------------------------------------------------------
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-digit-gmail-app-password

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
# Production example:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
