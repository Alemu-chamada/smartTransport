NODE_ENV=development
PORT=5002

# ── PostgreSQL Database ──────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=your_database_name
PGUSER=your_db_user
PGPASSWORD=your_db_password

# For Neon (production):
# PGHOST=ep-xxxxx.neon.tech
# PGPORT=5432
# PGDATABASE=neondb
# PGUSER=neondb_owner
# PGPASSWORD=your_neon_password

# ── Redis ───────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash (production): rediss://default:password@region.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRES_IN=1h

# ── OTP & Booking ───────────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=10
BOOKING_RESERVATION_MINUTES=15

# ── Email — Brevo API ───────────────────────────────────────
# Sign up at https://app.brevo.com → Settings → API Keys
BREVO_API_KEY=your_brevo_api_key_here

# ── Payment ─────────────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=replace_with_payment_webhook_secret
PAYMENT_SESSION_BASE_URL=https://payments.example.test/checkout

# ── CORS ────────────────────────────────────────────────────
# Set to your frontend URL in production
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
