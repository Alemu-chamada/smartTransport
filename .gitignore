# ============================================================
# Smart Transportation Management System — .gitignore
# ============================================================

# ----------------------------
# Dependencies
# ----------------------------
node_modules/
.pnp
.pnp.js
bower_components/
jspm_packages/

# ----------------------------
# Build outputs
# ----------------------------
dist/
build/
.next/
out/
.nuxt
.vite
.parcel-cache

# ----------------------------
# Environment files — NEVER COMMIT
# ----------------------------
.env
.env.local
.env.development
.env.production
backend/.env
frontend/.env
*.pem
*.key
*.cert

# Keep .env.example (template only — no real values)
!.env.example
!backend/.env.example

# ----------------------------
# Database & local SQL dumps
# ----------------------------
*.sql.backup
*.db
*.sqlite
*.sqlite3
dump.sql
dump.rdb
local_backup.sql
deployment/backups/
backups/*.sql
backups/*.sql.gz

# ----------------------------
# Logs
# ----------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------
# Runtime / process files
# ----------------------------
pids/
*.pid
*.seed
*.pid.lock

# ----------------------------
# Test coverage
# ----------------------------
coverage/
*.lcov
.nyc_output

# ----------------------------
# Cache
# ----------------------------
.cache
.npm
.eslintcache
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ----------------------------
# Temporary / scratch files
# ----------------------------
test-*.js
test-*.ts
*.test.local.js
*.spec.local.js
*.backup
*.bak
*.old
*.tmp
*.temp

# ----------------------------
# IDE / Editor
# ----------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ----------------------------
# OS generated
# ----------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----------------------------
# Package manager locks (keep package-lock at root if needed)
# ----------------------------
.pnp.*
.yarn-integrity
.node_repl_history
*.tgz

# ----------------------------
# Deployment secrets / generated
# ----------------------------
deployment/.vercel/
deployment/.env
deployment/.env.production
deployment/.env.local
deployment/secrets.txt
deployment/production-secrets.txt

# ----------------------------
# Docker overrides
# ----------------------------
docker-compose.override.yml
